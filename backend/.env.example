# FastAPI async URL — postgresql+asyncpg:// preferred; plain postgresql:// (Neon default) is auto-converted.
# ?sslmode=require on Neon is OK: the app strips it for asyncpg and uses TLS via connect_args.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/neondb?sslmode=require

# Alembic migrations (sync): plain postgresql:// — set on Render if you only set DATABASE_URL above
DATABASE_URL_SYNC=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

ALLOWED_ORIGINS=["http://localhost:3000","https://your-app.vercel.app"]
EMBEDDING_MODEL=all-MiniLM-L6-v2
